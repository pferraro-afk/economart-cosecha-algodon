# --- Google OAuth (Streamlit ≥1.42 nativo) ---
# LOCAL (.streamlit/secrets.toml en tu máquina):
[auth]
redirect_uri        = "http://localhost:8501/oauth2callback"
cookie_secret       = "generar_con: python -c \"import secrets; print(secrets.token_hex(32))\""
client_id           = "tu_google_client_id"
client_secret       = "tu_google_client_secret"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

# STREAMLIT CLOUD (Settings → Secrets, editor web):
# QUIRK: el header "[auth]" en su propia línea se pierde al guardar en ese editor.
# Usá la forma inline en una sola línea:
# auth = { redirect_uri = "https://tu-app.streamlit.app/oauth2callback", cookie_secret = "...", client_id = "...", client_secret = "...", server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration" }
